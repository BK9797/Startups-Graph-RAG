# ---------------------------------------------------------------------------
# Copy this file to .env and fill in real values. Never commit the real .env.
# ---------------------------------------------------------------------------

# --- Neo4j (AuraDB, Railway Neo4j plugin, or self-hosted) ---
NEO4J_URI=neo4j+s://xxxxxxxx.databases.neo4j.io
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=change-me
NEO4J_DATABASE=neo4j

# --- Groq LLM ---
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxx
GROQ_ANSWER_MODEL=llama-3.3-70b-versatile
GROQ_TEMPERATURE_ANSWER=0.2

# --- App ---
APP_ENV=development
CORS_ORIGINS=*
MAX_CYPHER_ROWS=50
REQUEST_TIMEOUT_SECONDS=30
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5

# --- Local server ---
PORT=8000
HOST=0.0.0.0

# --- Frontend (Streamlit) ---
# Point this at the deployed FastAPI service URL when frontend and backend
# are deployed as two separate Railway services.
BACKEND_URL=http://localhost:8000